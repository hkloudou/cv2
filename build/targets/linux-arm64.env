# Target definition: linux/arm64 (aarch64 cross build).
TARGET_GOOS=linux
TARGET_GOARCH=arm64
CMAKE_TOOLCHAIN=linux-arm64.cmake
CMAKE_EXTRA=""
WRAPPER_CXX=aarch64-linux-gnu-g++
WRAPPER_AR=aarch64-linux-gnu-ar
WRAPPER_CXXFLAGS="-fPIC"
LIBS_CGO_LDFLAGS='-L${SRCDIR} -lcv2wrapper -lopencv_imgproc -lopencv_core -lzlib -lstdc++ -lm -lpthread -ldl'
CI_APT_PACKAGES="gcc-aarch64-linux-gnu g++-aarch64-linux-gnu"
CROSS_CC=aarch64-linux-gnu-gcc
