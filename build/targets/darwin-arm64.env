# Target definition: darwin/arm64 (Apple Silicon, built natively on a
# macos-14 GitHub Actions runner with Apple clang).
TARGET_GOOS=darwin
TARGET_GOARCH=arm64
CMAKE_TOOLCHAIN=
# Carotene defaults on for every aarch64 target (Apple Silicon included)
# and would require linking libtegra_hal.a; KleidiCV likewise on OpenCV
# 4.10+. See linux-arm64.env.
CMAKE_EXTRA="-DCMAKE_OSX_DEPLOYMENT_TARGET=11.0 -DWITH_CAROTENE=OFF -DWITH_KLEIDICV=OFF"
WRAPPER_CXX=clang++
WRAPPER_AR=ar
WRAPPER_CXXFLAGS="-fPIC -mmacosx-version-min=11.0"
LIBS_CGO_LDFLAGS='-L${SRCDIR} -lcv2wrapper -lopencv_imgproc -lopencv_core -lzlib -lc++'
CI_APT_PACKAGES=""
CROSS_CC=clang
