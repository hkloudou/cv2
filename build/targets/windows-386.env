# Target definition: windows/386 (32-bit MinGW-w64 cross build, POSIX threads).
TARGET_GOOS=windows
TARGET_GOARCH=386
CMAKE_TOOLCHAIN=windows-386.cmake
CMAKE_EXTRA="-DCPU_BASELINE=SSE2"
WRAPPER_CXX=i686-w64-mingw32-g++-posix
WRAPPER_AR=i686-w64-mingw32-ar
WRAPPER_CXXFLAGS=""
LIBS_CGO_LDFLAGS='-L${SRCDIR} -lcv2wrapper -lopencv_imgproc -lopencv_core -lzlib -static -lstdc++ -lwinpthread'
CI_APT_PACKAGES="g++-mingw-w64-i686-posix"
CROSS_CC=i686-w64-mingw32-gcc-posix
