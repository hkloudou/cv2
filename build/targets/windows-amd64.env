# Target definition: windows/amd64 (MinGW-w64 cross build, POSIX threads).
# Users build their Go programs with an MSYS2/MinGW-w64 x86_64 toolchain.
TARGET_GOOS=windows
TARGET_GOARCH=amd64
CMAKE_TOOLCHAIN=windows-amd64.cmake
CMAKE_EXTRA=""
WRAPPER_CXX=x86_64-w64-mingw32-g++-posix
WRAPPER_AR=x86_64-w64-mingw32-ar
WRAPPER_CXXFLAGS=""
# ole32 backs CoCreateGuid, which OpenCV 5.0 core (cv::tempfile) references.
LIBS_CGO_LDFLAGS='-L${SRCDIR} -lcv2wrapper -lopencv_imgproc -lopencv_core -lzlib -static -lstdc++ -lwinpthread -lole32'
CI_APT_PACKAGES="g++-mingw-w64-x86-64-posix"
CROSS_CC=x86_64-w64-mingw32-gcc-posix
