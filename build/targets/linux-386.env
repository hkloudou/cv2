# Target definition: linux/386 (32-bit x86, built with -m32 multilib).
TARGET_GOOS=linux
TARGET_GOARCH=386
CMAKE_TOOLCHAIN=linux-386.cmake
CMAKE_EXTRA="-DCPU_BASELINE=SSE2"
WRAPPER_CXX=g++
WRAPPER_AR=ar
WRAPPER_CXXFLAGS="-m32 -fPIC"
LIBS_CGO_LDFLAGS='-L${SRCDIR} -lcv2wrapper -lopencv_imgproc -lopencv_core -lzlib -lstdc++ -lm -lpthread -ldl'
CI_APT_PACKAGES="gcc-multilib g++-multilib"
CROSS_CC=gcc
