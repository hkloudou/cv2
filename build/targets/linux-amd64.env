# Target definition: linux/amd64 (native build on ubuntu runners).
TARGET_GOOS=linux
TARGET_GOARCH=amd64
CMAKE_TOOLCHAIN=
CMAKE_EXTRA=""
WRAPPER_CXX=g++
WRAPPER_AR=ar
WRAPPER_CXXFLAGS="-fPIC"
LIBS_CGO_LDFLAGS='-L${SRCDIR} -lcv2wrapper -lopencv_imgproc -lopencv_core -lzlib -lstdc++ -lm -lpthread -ldl'
CI_APT_PACKAGES=""
CROSS_CC=gcc
